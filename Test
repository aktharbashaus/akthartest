# Apps
az webapp list \
  --resource-group odhapps-sbx-odrs-rg \
  --query "[].{Name:name, Type:'App', PrincipalId:identity.principalId}" \
  -o table

# Slots  
az webapp list \
  --resource-group odhapps-sbx-odrs-rg \
  --query "[].name" -o tsv | while read app; do
  az webapp deployment slot list \
    --name $app \
    --resource-group odhapps-sbx-odrs-rg \
    --query "[].{App:'$app', Slot:name, PrincipalId:identity.principalId}" \
    -o table
done
