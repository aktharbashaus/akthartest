# DEBUG - Network connectivity check
Write-Host ""
Write-Host "=== NETWORK DEBUG ==="

# Check DNS resolution
Write-Host "DNS Resolution:"
Resolve-DnsName -Name "$CosmosAccount.documents.azure.com" | 
    ForEach-Object { Write-Host "  -> $($_.Name) : $($_.IPAddress)" }

# Check if private endpoint exists
Write-Host "Cosmos Network Config:"
az cosmosdb show `
    --name $CosmosAccount `
    --resource-group $ResourceGroup `
    --query "{publicAccess:publicNetworkAccess, privateEndpoints:privateEndpointConnections}" `
    --output json

# Test TCP connectivity to port 443
Write-Host "TCP Connectivity Test:"
$tcpTest = Test-NetConnection `
    -ComputerName "$CosmosAccount.documents.azure.com" `
    -Port 443
Write-Host "  TCP Success: $($tcpTest.TcpTestSucceeded)"
Write-Host "  Remote Address: $($tcpTest.RemoteAddress)"
Write-Host "  Remote Port: $($tcpTest.RemotePort)"

Write-Host "=== END NETWORK DEBUG ==="
Write-Host ""
